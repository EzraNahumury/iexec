# ===========================================================================
# StealthGive — environment variables TEMPLATE
# Copy to `.env` and fill in. NEVER put real secrets here — this file IS
# committed to git (so contributors know which variables to set).
# ===========================================================================

# RPC endpoints
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARB_RPC=https://arb1.arbitrum.io/rpc

# Deployer key (use a fresh key for testnets, never reuse a mainnet key)
PRIVATE_KEY=0x...

# Block explorer verification
ARBISCAN_API_KEY=

# iExec Nox Confidential Token (cUSDC test deployment, get the address from the
# CDeFi faucet at https://cdefi.iex.ec/ after wrapping test USDC).
CONFIDENTIAL_TOKEN_ADDRESS=0x...

# Optional: override the default refund grace period (seconds) when running
# the deployment script. Default in script: 7 days.
REFUND_GRACE_PERIOD=
